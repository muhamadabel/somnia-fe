# Copy this file to .env and fill in the values.

# Database (SQLite for local/demo; swap to PostgreSQL for production)
DATABASE_URL="file:./dev.db"

# Random string used to protect sessions — REQUIRED, change in production
SESSION_SECRET=""

# ── AI ─────────────────────────────────────────────────────────────────
# Default: FREE, key-less AI (Pollinations.ai) — real LLM with full dream
# memory + free AI image generation. Falls back to the offline engine if
# the service is unreachable.
#
#   AI_MODE=local   → offline built-in engine only (no internet)
#   (unset)         → free Pollinations AI (default)
AI_MODE=""

# Optional: use Claude instead (highest quality) by providing a key.
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-5"
