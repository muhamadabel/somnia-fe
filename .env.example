# Salin file ini ke .env.local lalu isi nilainya.
#
# Ini adalah FRONTEND (SPA). Semua data & AI ditangani oleh backend terpisah
# (repo somnia-be). Frontend hanya butuh satu variabel: alamat backend.

# -- Alamat API backend ------------------------------------------------------
# URL penuh backend, TANPA garis miring di akhir.
#   Lokal (backend jalan di komputermu):   http://localhost:3001
#   Produksi (punya temanmu):              https://be-somnia.hallojanu.xyz
#
# WAJIB diawali NEXT_PUBLIC_ agar terbaca di browser. Nilainya "dibakar" saat
# build, jadi setel dulu di Vercel sebelum deploy (lihat README).
NEXT_PUBLIC_API_URL="https://be-somnia.hallojanu.xyz"
